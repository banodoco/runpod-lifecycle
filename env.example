# RunPod credentials and defaults — copy to .env and fill in.
# This package owns RunPod lifecycle only. Orchestrator-level concerns
# (Supabase, scaling, worker repo paths) live in the consuming app's .env.

RUNPOD_API_KEY=your_runpod_api_key_here

# Defaults (override at runtime via RunPodConfig)
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 4090
RUNPOD_WORKER_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04
RUNPOD_VOLUME_MOUNT_PATH=/workspace
RUNPOD_DISK_SIZE_GB=20
RUNPOD_CONTAINER_DISK_GB=50
RUNPOD_STORAGE_NAME=your_network_volume_name

# SSH keys for pod exec
RUNPOD_SSH_PUBLIC_KEY="ssh-ed25519 AAAA... user@host"
RUNPOD_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
...
-----END OPENSSH PRIVATE KEY-----"

# RunPod-S3 (network volume access) — optional
AWS_ACCESS_KEY_ID=user_xxx
AWS_SECRET_ACCESS_KEY=rps_xxx
AWS_DEFAULT_REGION=eu-ro-1
